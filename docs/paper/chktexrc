# Local ChkTeX config for this project.
# Keep useful structural warnings; suppress selected noisy style warnings.

CmdLine {
    -n1   # Command terminated with space
    -n2   # Non-breaking space (~) should have been used
    -n8   # Wrong length of dash may have been used
    -n11  # Use \ldots
    -n12  # Interword spacing (\ ) should perhaps be used
    -n18  # Quote-style warning
    -n36  # Space in front of parenthesis
    -n38  # Punctuation in front of quotes
}